{
  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px",
    "2xl": "48px",
    "3xl": "64px"
  },
  "typography": {
    "fontFamily": "Inter, sans-serif",
    "scale": {
      "display": { "size": "32px", "weight": "900", "tracking": "-0.02em" },
      "h1": { "size": "24px", "weight": "900", "tracking": "-0.01em" },
      "h2": { "size": "20px", "weight": "800", "tracking": "normal" },
      "bodyLarge": { "size": "16px", "weight": "500", "tracking": "normal" },
      "bodyBase": { "size": "14px", "weight": "400", "tracking": "normal" },
      "caption": { "size": "12px", "weight": "600", "tracking": "normal" },
      "micro": { "size": "10px", "weight": "700", "tracking": "0.05em", "case": "uppercase" }
    }
  },
  "colors": {
    "admin": {
      "primary": "#8B5CF6",
      "surface": "#FFFFFF",
      "background": "#F8F9FA"
    },
    "provider": {
      "primary": "#EA580C",
      "surface": "#FFFFFF",
      "background": "#F8F9FA"
    },
    "client": {
      "primary": "#2563EB",
      "surface": "#FFFFFF",
      "background": "#F8F9FA"
    },
    "neutral": {
      "ink": "#1A1A1A",
      "gray": "#64748B",
      "border": "#F1F5F9"
    }
  },
  "shadows": {
    "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
    "md": "0 4px 6px -1px rgba(0, 0, 0, 0.1)",
    "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1)",
    "glass": "blur(12px) saturate(180%)"
  },
  "interaction": {
    "hover": { "brightness": "90%", "scale": "1.02" },
    "active": { "scale": "0.95" },
    "focus": { "ring": "2px", "offset": "4px" }
  }
}
