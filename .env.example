# ═══════════════════════════════════════════════════════════════════════════════
# TEST ACCOUNTS (Development / Testing Only)
# ═══════════════════════════════════════════════════════════════════════════════
# All test accounts use OTP code: 1234
#
# Admin:    Amani         +966 55 512 3456  (or 0555123456)
# Provider: Manal         +966 50 546 7269  (or 0505467269)
# Client:   Lyla          +966 58 231 4923  (or 0582314923)

# ─── Node.js / Express Backend ────────────────────────────────────────────────

# Turso (LibSQL) — required in production; falls back to file:zeina.db in dev
TURSO_URL="libsql://your-db-name-yourname.turso.io"
TURSO_TOKEN="your-turso-jwt-token"

# Server
NODE_ENV="development"
PORT="3001"

# Admin login password — CHANGE THIS before production
ADMIN_PASSWORD="change-me-before-production"

# CORS — set to your frontend domain in production (e.g. https://ziena.sa)
# Leave empty in dev (allows localhost)
ALLOWED_ORIGIN=""

# .NET backend URL used by Node.js server-side proxy and merchant auto-registration
DOTNET_API_URL="http://localhost:5000"

# Google AI (optional — not deeply integrated yet)
GEMINI_API_KEY="your-gemini-api-key"

# ─── React Frontend (Vite build-time) ─────────────────────────────────────────
# URL of the deployed .NET 10 backend — baked into the React bundle at build time.
# In development this is not needed; Vite proxies /dotnet-api to http://localhost:5000.
VITE_DOTNET_API_URL="https://your-dotnet-service.onrender.com"

# URL of the deployed Node.js/Express backend — needed for Capacitor APK.
# The APK uses file:// scheme so relative /api URLs won't work.
# Set this at APK build time: VITE_API_BASE_URL=https://your-app.onrender.com/api npm run build
# In development this is not needed; Vite proxies /api to http://localhost:3001.
VITE_API_BASE_URL="https://your-app.onrender.com/api"

# ─── .NET 10 Backend (Ziena.Backend) ──────────────────────────────────────────
# VAPID keys for web push — generated automatically on first run.
# Set in production to survive re-deploys without losing push subscriptions.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# Set these in Render (or appsettings.Production.json — never commit credentials).
# ASPNETCORE_ENVIRONMENT="Production"
# ConnectionStrings__Default="Data Source=ziena.db"

# ─── Moyasar Payment Gateway ───────────────────────────────────────────────
# Register at https://dashboard.moyasar.com → API Keys section
# Sandbox test card: 4111111111111111  exp 05/30  CVV 123
MOYASAR_SECRET_KEY="sk_test_your_key_here"
MOYASAR_PUBLISHABLE_KEY="pk_test_your_key_here"
# Webhook secret: Moyasar dashboard → Webhooks → copy signing secret
MOYASAR_WEBHOOK_SECRET="your_webhook_secret_here"

# ─── OTPless (WhatsApp OTP) ────────────────────────────────────────────────
# Register at https://otpless.com → Dashboard → App credentials
# When set: OTPs are sent via WhatsApp (better delivery in KSA than SMS)
# When not set: random code is printed to server console (dev/test mode)
OTPLESS_CLIENT_ID=""
OTPLESS_CLIENT_SECRET=""

# ─── Upstash Redis (required on Vercel; optional on Render) ───────────────
# Needed for rate limiting on Vercel serverless (in-memory Map doesn't persist).
# Create a Redis DB at https://console.upstash.com → copy REST URL and token.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Sentry (error tracking) ──────────────────────────────────────────────
# Free plan: 5,000 errors/month. Register at https://sentry.io
# SENTRY_DSN goes to the Node.js/Express backend
# VITE_SENTRY_DSN goes to the React frontend (baked in at build time)
SENTRY_DSN=""
VITE_SENTRY_DSN=""

# ─── PostHog (product analytics) ──────────────────────────────────────────
# Free plan: 1M events/month. Register at https://posthog.com
# Baked into React bundle at build time
VITE_POSTHOG_KEY=""
