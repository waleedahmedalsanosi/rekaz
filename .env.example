# ─── Node.js / Express Backend ────────────────────────────────────────────────

# Turso (LibSQL) — required in production; falls back to file:zeina.db in dev
TURSO_URL="libsql://your-db-name-yourname.turso.io"
TURSO_TOKEN="your-turso-jwt-token"

# Server
NODE_ENV="development"
PORT="3001"

# Google AI (optional — not deeply integrated yet)
GEMINI_API_KEY="your-gemini-api-key"

# ─── React Frontend (Vite build-time) ─────────────────────────────────────────
# URL of the deployed .NET 10 backend — baked into the React bundle at build time.
# In development this is not needed; Vite proxies /dotnet-api to http://localhost:5000.
VITE_DOTNET_API_URL="https://your-dotnet-service.onrender.com"

# ─── .NET 10 Backend (Ziena.Backend) ──────────────────────────────────────────
# Set these in Render (or appsettings.Production.json — never commit credentials).
# ASPNETCORE_ENVIRONMENT="Production"
# ConnectionStrings__Default="Data Source=ziena.db"
